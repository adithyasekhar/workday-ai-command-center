# ─── Workday Credentials ─────────────────────
WORKDAY_TENANT=your_company_name
WORKDAY_BASE_URL=https://wd2.myworkday.com/ccx/api/v1/your_company
WORKDAY_TOKEN_URL=https://wd2.myworkday.com/ccx/oauth2/your_company/token
WORKDAY_CLIENT_ID=your_client_id
WORKDAY_CLIENT_SECRET=your_client_secret
WORKDAY_REFRESH_TOKEN=your_refresh_token
WORKDAY_REPORT_URL=your_custom_report_json_url

# ─── AI Keys ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_openai_key_here
GEMINI_API_KEY=AIza-your_gemini_key_here

# ─── Notification Channels ───────────────────
TEAMS_WEBHOOK_URL=https://your_company.webhook.office.com/your_webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=your@gmail.com
EMAIL_TO=hris@yourcompany.com,manager@yourcompany.com
OUTLOOK_SMTP_HOST=smtp.office365.com
OUTLOOK_SMTP_PORT=587
OUTLOOK_USERNAME=your@company.com
OUTLOOK_PASSWORD=your_outlook_password
OUTLOOK_TO=hris@company.com
ZOOM_WEBHOOK_URL=https://your_zoom_webhook_url
ZOOM_VERIFICATION_TOKEN=your_zoom_token

# ─── Settings ────────────────────────────────
ENABLE_MULTI_AI=true
POLL_INTERVAL_MINUTES=30
